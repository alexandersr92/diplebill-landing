# Producción. Solo variables NEXT_PUBLIC_* (públicas: se inyectan en el bundle
# del cliente en `next build`). Vercel puede sobrescribirlas desde su dashboard.
NEXT_PUBLIC_API_URL=https://api.diplebill.com
NEXT_PUBLIC_ADMIN_URL=https://app.diplebill.com

# El client ID de Google es público pero varía por proyecto: setéalo en Vercel
# (o descomenta y pégalo aquí). Sin él, el registro con Google no funciona.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
