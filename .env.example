# URL base del backend (sin /api — el código agrega /api/v1/...)
# Registro por correo:  POST {NEXT_PUBLIC_API_URL}/api/v1/register
# Registro con Google:  POST {NEXT_PUBLIC_API_URL}/api/v1/auth/google  {token, device_name}
NEXT_PUBLIC_API_URL=http://localhost:8000

# URL del panel de administración (a donde se envía al usuario tras registrarse)
NEXT_PUBLIC_ADMIN_URL=http://localhost:5173

# Client ID de OAuth de Google (Google Cloud Console → Credentials).
# Si no se define, el botón de Google no se muestra y solo queda el registro por correo.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
