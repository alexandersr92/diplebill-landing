# URL del backend (API de registro y OAuth de Google)
# El formulario hace POST a {NEXT_PUBLIC_API_URL}/v1/register
# y el botón de Google redirige a {NEXT_PUBLIC_API_URL}/v1/auth/google?trial=true
NEXT_PUBLIC_API_URL=http://localhost:8000

# URL del panel de administración (a donde se envía al usuario tras registrarse)
NEXT_PUBLIC_ADMIN_URL=http://localhost:5173
